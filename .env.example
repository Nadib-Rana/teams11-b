# Database
DATABASE_URL=postgresql://username:password@localhost:5432/devscout

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRATION=86400

# MinIO Configuration
## MinIO Server (Local - Docker Compose)
MINIO_ENDPOINT=minio
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=devscout

# For production:
# MINIO_ENDPOINT=minio.yourdomain.com
# MINIO_PORT=9000
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=your-production-access-key
# MINIO_SECRET_KEY=your-production-secret-key

# Email Configuration (Gmail example)
MAIL_HOST=smtp.gmail.com
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@devscout.com
MAIL_FROM_NAME=DevScout

# Firebase (Optional)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Application
NODE_ENV=development
APP_PORT=3000
