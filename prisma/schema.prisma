generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}


// --- Enums ---
enum UserRole {
  customer
  vendor
  staff
}

enum BookingStatus {
  pending
  waiting
  confirmed
  cancelled
}

enum BookingType {
  virtual
  in_person
}

enum ServiceType {
  service
  event
  class
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum TokenType {
  email_verification
  password_reset
  login_otp
}

// --- Models ---

model User {
  id            String    @id @default(uuid()) @db.Uuid
  fullName      String?   @map("full_name")
  email         String    @unique
  password      String
  role          UserRole
  phone         String?   // optional phone number for user
  /// Stores MinIO object key for profile image (not full URL). Format: users/{userId}/profile-{timestamp}
  profileImage  String?   @map("profile_image")
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  customer             Customer?
  vendor               Vendor?
  staff                Staff?
  notifications        Notification[]
  notificationSettings NotificationSetting?
  referralsMade        Referral[] @relation("Referrer")
  verificationTokens   VerificationToken[]

  @@map("users")
}

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@map("verification_tokens")
}

model Customer {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id])
  referralCode String?   @map("referral_code")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  bookings    Booking[]
  waitingList WaitingList[]
  reviews     Review[]
  favorites   Favorite[]

  @@map("customers")
}

model Vendor {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  user          User      @relation(fields: [userId], references: [id])
  referralCode  String?   @map("referral_code")
  referredBy    String?   @map("referred_by") @db.Uuid
  referralCount Int       @default(0) @map("referral_count")
  bonusBalance  Decimal   @default(0) @map("bonus_balance") @db.Decimal(10, 2)
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  businesses    Business[]
  referralsRecv Referral[] @relation("ReferredVendor")
  subscriptions Subscription[]
  payments      Payment[]

  @@map("vendors")
}

model Business {
  id          String    @id @default(uuid()) @db.Uuid
  vendorId    String    @map("vendor_id") @db.Uuid
  vendor      Vendor    @relation(fields: [vendorId], references: [id])
 
  //Business will be create using category.
  categoryId String? @map("category_id") @db.Uuid
  category Category? @relation(fields: [categoryId], references: [id])
  
  name        String
  description String?
  /// Stores MinIO object key for logo (not full URL). Format: businesses/{businessId}/logo-{timestamp}
  logoKey     String?   @map("logo")
  location    String?
  createdAt   DateTime  @default(now()) @map("created_at")

  workingDays Json? @map("working_days")

  // Relations
  images     BusinessImage[]
  staff      Staff[]
  services   Service[]
  bookings   Booking[]
  guests     GuestCustomer[]
  reviews    Review[]
  favoritedBy Favorite[]

  @@map("businesses")
}

model BusinessImage {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  /// Stores MinIO object key (not full URL). Format: businesses/{businessId}/images/{key}
  imageKey   String   @map("image_url")

  @@map("business_images")
}

model Staff {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  businessId  String   @map("business_id") @db.Uuid
  business    Business @relation(fields: [businessId], references: [id])
  role        String?
  specialties String?
  workingDays Json?    @map("working_days")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  services StaffService[]
  bookings Booking[]

  @@map("staff")
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String
  /// Stores MinIO object key for category image (not full URL). Format: categories/{categoryId}/image-{timestamp}
  image String?

  // Relations
  businesses Business[]
  services Service[]

  @@map("categories")
}

model Service {
  id          String      @id @default(uuid()) @db.Uuid
  businessId  String      @map("business_id") @db.Uuid
  business    Business    @relation(fields: [businessId], references: [id])
  categoryId  String?      @map("category_id") @db.Uuid
  category    Category?    @relation(fields: [categoryId], references: [id])
  title       String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  duration    Int // Duration in minutes
  color       String?
  type        ServiceType

  // Relations
  staff       StaffService[]
  bookings    Booking[]
  waitingList WaitingList[]

  @@map("services")
}

model StaffService {
  staffId   String  @map("staff_id") @db.Uuid
  staff     Staff   @relation(fields: [staffId], references: [id])
  serviceId String  @map("service_id") @db.Uuid
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
  @@map("staff_services")
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  customerId   String        @map("customer_id") @db.Uuid
  customer     Customer      @relation(fields: [customerId], references: [id])

  businessId   String        @map("business_id") @db.Uuid
  business     Business      @relation(fields: [businessId], references: [id])

  serviceId    String        @map("service_id") @db.Uuid
  service      Service       @relation(fields: [serviceId], references: [id])

  staffId      String?        @map("staff_id") @db.Uuid
  staff        Staff?         @relation(fields: [staffId], references: [id])

  bookingType  BookingType   @map("booking_type")
  status       BookingStatus
  date         DateTime      @db.Date
  startTime    DateTime      @map("start_time") @db.Time
  endTime      DateTime      @map("end_time") @db.Time
  cancelReason String?       @map("cancel_reason")
  createdAt    DateTime      @default(now()) @map("created_at")

  // Relations
  reviews  Review[]
  payments Payment[]

  @@map("bookings")
}

model WaitingList {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  customer      Customer @relation(fields: [customerId], references: [id])
  serviceId     String   @map("service_id") @db.Uuid
  service       Service  @relation(fields: [serviceId], references: [id])
  preferredDate DateTime @map("preferred_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("waiting_list")
}

model GuestCustomer {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  email      String?
  image      String?
  address    String?

  @@map("guest_customers")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid

  bookingId  String   @map("booking_id") @db.Uuid
  booking    Booking  @relation(fields: [bookingId], references: [id])

  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])

  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id])

  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@map("reviews")
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid

  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id])

  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id])

  @@map("favorites")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid

  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model NotificationSetting {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @unique @map("user_id") @db.Uuid
  user              User    @relation(fields: [userId], references: [id])
  emailNotification Boolean @default(true) @map("email_notifications")
  pushNotification  Boolean @default(true) @map("push_notifications")
  bookingReminders  Boolean @default(true) @map("booking_reminders")

  @@map("notification_settings")
}

model Referral {
  id               String   @id @default(uuid()) @db.Uuid
  referrerUserId   String   @map("referrer_user_id") @db.Uuid
  referrer         User     @relation("Referrer", fields: [referrerUserId], references: [id])
  referredVendorId String   @map("referred_vendor_id") @db.Uuid
  referredVendor   Vendor   @relation("ReferredVendor", fields: [referredVendorId], references: [id])
  bonusAmount      Decimal  @map("bonus_amount") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("referrals")
}

model SubscriptionPlan {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  price    Decimal @db.Decimal(10, 2)
  maxUsers Int    @map("max_users")
  features String?

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  planId    String   @map("plan_id") @db.Uuid
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String

  @@map("subscriptions")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String?       @map("booking_id") @db.Uuid
  booking       Booking?      @relation(fields: [bookingId], references: [id])
  vendorId      String        @map("vendor_id") @db.Uuid
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod String        @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("payments")
}