<div
  style="max-width:600px;margin:auto;background:#ffffff;border-radius:10px;border:1px solid #eaeaea;font-family:Arial,Helvetica,sans-serif;overflow:hidden"
>

  <!-- Header -->
  <div style="background:#4CAF50;padding:25px;text-align:center;color:white">
    <h1 style="margin:0;font-size:24px;">Teams11</h1>
    <p style="margin:5px 0 0;font-size:14px;opacity:0.9;">Secure Email
      Verification</p>
  </div>

  <!-- Body -->
  <div style="padding:30px;color:#333;line-height:1.6">

    <h2 style="margin-top:0;color:#222;">Welcome to Teams11 👋</h2>

    <p>Hello <strong>{{name}}</strong>,</p>

    <p>
      Thank you for joining
      <strong>Teams11</strong>. Please use the verification code below to
      confirm your email address.
    </p>

    <!-- OTP Box -->
    <div style="margin:30px 0;text-align:center">
      <div
        style="display:inline-block;background:#f7f7f7;border:2px dashed #4CAF50;padding:18px 30px;font-size:28px;font-weight:bold;letter-spacing:6px;color:#4CAF50;border-radius:8px"
      >
        {{otp}}
      </div>
    </div>

    <p style="text-align:center;font-size:14px;color:#666">
      This verification code will expire in
      <strong>5 minutes</strong>.
    </p>

    <p style="margin-top:25px">
      If you did not request this verification, you can safely ignore this
      email.
    </p>

  </div>

  <!-- Footer -->
  <div
    style="background:#fafafa;padding:20px;text-align:center;font-size:12px;color:#888;border-top:1px solid #eee"
  >
    <p style="margin:0">© 2026 Teams11. All rights reserved.</p>
    <p style="margin:5px 0 0">This is an automated email, please do not reply.</p>
  </div>

</div>